        "jsCode": "const out = JSON.parse($json.stdout.trim());\nif (out.error) { throw new Error('인포그래픽 데이터 생성 실패: ' + out.error); }\nreturn [{ json: { data_file: out.data_file, topic_id: out.topic_id, title: out.title } }];"
      }
    },
