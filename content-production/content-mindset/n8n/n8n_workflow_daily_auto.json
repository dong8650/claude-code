      "name": "Daily Plan",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300],
      "parameters": {
        "jsCode": "const now = new Date();\nconst day = now.getDay();\n// 내레이션: 일(0) 월(1) 수(3) 금(5) / 다큐: 화(2) 목(4) 토(6)\nconst videoType = [0,1,3,5].includes(day) ? 'narration' : 'docu';\nconst dayNames = ['일','월','화','수','목','금','토'];\nconsole.log('[Daily Plan] ' + dayNames[day] + '요일 videoType=' + videoType);\nreturn [{ json: { videoType } }];"
      }
    },
