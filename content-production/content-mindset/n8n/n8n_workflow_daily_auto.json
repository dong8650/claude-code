    {
      "id": "node-code-info-meta",
      "name": "Infographic Metadata",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1780, 300],
      "parameters": {
        "jsCode": "const data = JSON.parse($json.stdout.trim());\nconst title = data.title || $('Parse Infographic Topic').item.json.title || '';\nconst subtitle = data.subtitle || '';\nconst tags = data.tags_ko || ['매일의설계','직장인','쇼츠','인포그래픽','데이터'];\nconst dataFile = $('Parse Infographic Topic').item.json.data_file;\nconst video_path = dataFile.replace('.json', '.mp4');\nconst tagsLine = tags.map(t => '#' + t).join(' ');\nconst lines = [\n  subtitle, '',\n  '─────────────────────────',\n  '📌 매일의설계 | 어제보다 나은 오늘을 설계하자',\n  '오늘의 일과 돈을 하나씩 다시 설계합니다.'\n];\nif (tagsLine) { lines.push('', tagsLine); }\nconst desc = lines.join('\\n');\nreturn [{ json: { title, description_full: desc, tags_ko: tags, video_path, privacy: 'private' } }];"
      }
    },
    {
      "id": "node-read-info-video",
      "name": "Read Infographic Video",
      "type": "n8n-nodes-base.readWriteFile",
      "typeVersion": 1,
      "position": [2000, 300],
