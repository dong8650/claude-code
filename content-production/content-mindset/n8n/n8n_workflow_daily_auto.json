        "command": "={{ 'cd /root/claude-code/content-production/content-mindset && python3 generate_infographic.py --data ' + $('Parse Infographic Topic').item.json.data_file + ' --video --duration 7 --bgm /root/content/runtime/mindset/bgm/bgm_infographic.mp3 2>&1' }}"
