    {
      "id": "node-code-ep-meta",
      "name": "Episode Metadata",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3100, 300],
      "parameters": {
        "jsCode": "const raw = JSON.parse($json.stdout.trim());\nif (raw.error) {\n  return [{ json: { error: raw.error, ep_dir: raw.ep_dir || '', video_path: null, title: null } }];\n}\nconst { title, script_ko, closing_ko, tags_ko, video_path, style } = raw;\nconst tags = tags_ko || ['매일의설계','직장인','쇼츠','자기계발'];\nconst tagsLine = tags.map(t => '#' + t).join(' ');\nconst lines = [\n  script_ko, '',\n  '💡 ' + closing_ko, '',\n  '─────────────────────────',\n  '📌 매일의설계 | 어제보다 나은 오늘을 설계하자',\n  '오늘의 일과 돈을 하나씩 다시 설계합니다.'\n];\nif (tagsLine) { lines.push('', tagsLine); }\nif (style === 'docsul') {\n  lines.push(\n    '', '─────────────────────────',\n    '🎵 BGM: \"Dark Cinematic\" by Kevin MacLeod (incompetech.com)',\n    'Licensed under Creative Commons: By Attribution 3.0',\n    'http://creativecommons.org/licenses/by/3.0/'\n  );\n}\nconst desc = lines.join('\\n');\nreturn [{ json: { title, description_full: desc, tags_ko: tags, video_path, error: null, privacy: 'private' } }];"
      }
    },
